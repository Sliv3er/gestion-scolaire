<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.school.gestion.controller.TeacherDashboardController"
      styleClass="main-container">

    <VBox styleClass="sidebar" prefWidth="250">
        <Label text="GESTION SCOLAIRE" styleClass="sidebar-label"/>

        <VBox spacing="5" VBox.vgrow="ALWAYS">
            <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#navigateToDashboard" maxWidth="Infinity"/>
            <Button text="✍️  Saisie des notes" styleClass="nav-button" onAction="#navigateToNotes" maxWidth="Infinity"/>
            <Button text="👥  Mes élèves" styleClass="nav-button" onAction="#navigateToMesEleves" maxWidth="Infinity"/>
        </VBox>

        <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout" maxWidth="Infinity" style="-fx-padding: 20;"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS">
        <HBox styleClass="header-bar">
            <Label fx:id="headerTitle" text="Tableau de bord" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" text="" textFill="#757575"/>
        </HBox>

        <ScrollPane styleClass="content-area" fitToWidth="true">
            <VBox fx:id="contentArea" spacing="20" prefWidth="950"/>
        </ScrollPane>
    </VBox>
</HBox>
